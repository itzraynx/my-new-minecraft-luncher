# Nokiatis Launcher Environment Configuration
# Copy this file to .env and fill in your values

# CurseForge API Configuration
# You need to apply for a CurseForge API key at: https://console.curseforge.com/
# If you don't have an API key, the launcher will work but CurseForge features will be disabled
CURSEFORGE_API_BASE=https://api.curseforge.com
CURSEFORGE_API_KEY=your_curseforge_api_key_here

# Base API URL (for launcher backend services)
# Leave as default for local development
GDL_BASE_API=http://localhost:3000

# User Agent prefix for API requests
USER_AGENT_PREFIX=NokiatisLauncher
