{
  "name": "@gd/desktop",
  "productName": "GDLauncher",
  "private": true,
  "description": "GDLauncher Carbon.",
  "author": "GorillaDevs Inc.",
  "license": "ARR",
  "type": "module",
  "_comment": "DO NOT MANUALLY EDIT THE VERSION",
  "version": "0.0.0",
  "main": "dist/main/index.cjs",
  "scripts": {
    "dev": "node scripts/watch.mjs",
    "test": "playwright test",
    "build-vite": "node scripts/build.mjs",
    "patch-version": "node scripts/monkeypatchVersion.mjs",
    "build-electron": "cross-env-shell DEBUG=electron-builder ow-electron-builder --config .electron-builder.config.cjs",
    "build": "pnpm patch-version && pnpm build-vite && pnpm build-electron",
    "clean": "node scripts/cleanReleaseFolder.mjs",
    "lint": "tsc && pnpm --dir ../.. exec eslint apps/desktop --quiet && pnpm --dir ../.. exec prettier --check apps/desktop",
    "lint-fix": "tsc && pnpm --dir ../.. exec eslint apps/desktop --quiet --fix && pnpm --dir ../.. exec prettier --write apps/desktop",
    "release": "node scripts/releaseDraft.mjs"
  },
  "devDependencies": {
    "@electron/notarize": "^3.0.2",
    "@formkit/auto-animate": "^0.8.2",
    "@gd/config": "workspace:*",
    "@gd/core_module": "workspace:*",
    "@gd/i18n": "workspace:*",
    "@gd/ui": "workspace:*",
    "@overwolf/ow-electron": "37.2.6",
    "@overwolf/ow-electron-builder": "^24.13.8",
    "@playwright/test": "^1.49.1",
    "@rive-app/canvas": "^2.21.5",
    "@rspc/client": "0.2.0",
    "@rspc/solid": "0.2.0",
    "@sentry/electron": "^4.23.0",
    "@sentry/vite-plugin": "^2.14.2",
    "@solid-primitives/deep": "^0.2.3",
    "@solid-primitives/keyboard": "^1.2.6",
    "@solid-primitives/map": "^0.4.8",
    "@solidjs/router": "^0.9.1",
    "@tanstack/solid-query": "^5.30.6",
    "@tanstack/solid-table": "^8.20.5",
    "@tanstack/solid-virtual": "3.4.0",
    "@types/lodash": "^4.17.20",
    "@types/marked": "^5.0.2",
    "@types/sanitize-html": "^2.9.1",
    "@unocss/reset": "^0.65.1",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "electron": "37.2.6",
    "electron-log": "^5.1.1",
    "electron-updater": "^6.3.9",
    "fs-extra": "^11.2.0",
    "html-parse-string": "^0.0.9",
    "jsdom": "^25.0.1",
    "lodash": "^4.17.21",
    "marked": "^15.0.3",
    "playwright": "^1.49.1",
    "sanitize-html": "^2.13.1",
    "solid-js": "^1.9.3",
    "solid-transition-group": "^0.2.3",
    "virtua": "0.41.2",
    "vite": "^6.3.4",
    "vite-plugin-solid": "^2.11.6"
  },
  "env": {
    "//": "Used in build scripts",
    "PORT": 3344
  }
}
