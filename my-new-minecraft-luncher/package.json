{
  "name": "nokiatis-launcher",
  "version": "0.1.0",
  "private": true,
  "description": "Nokiatis Launcher - A Minecraft Launcher built with Rust backend, SolidJS frontend, and Electron",
  "workspaces": [
    "apps/desktop/packages/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "build": "pnpm run --parallel build",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,css,json}\""
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "pnpm@8.12.0"
}
