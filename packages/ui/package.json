{
  "name": "@gd/ui",
  "type": "module",
  "module": "./dist/ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ui.es.js"
    },
    "./style.css": "./src/style.css"
  },
  "scripts": {
    "build": "vite build --",
    "dev": "vite build --watch",
    "showcase:dev": "vite --config showcase/vite.config.mjs",
    "showcase:build": "vite build --config showcase/vite.config.mjs",
    "showcase:preview": "vite preview --config showcase/vite.config.mjs",
    "lint": "tsc && pnpm --dir ../.. exec eslint packages/ui --quiet && pnpm --dir ../.. exec prettier --check packages/ui",
    "lint-fix": "tsc && pnpm --dir ../.. exec eslint packages/ui --quiet --fix && pnpm --dir ../.. exec prettier --write packages/ui"
  },
  "pnpm": {
    "overrides": {
      "@tanstack/react-router": "npm:@tanstack/solid-router"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.22.5",
    "@floating-ui/dom": "^1.4.1",
    "@gd/config": "workspace:*",
    "@kobalte/core": "^0.13.7",
    "@tanstack/router-vite-plugin": "^1.94.2",
    "@tanstack/solid-router": "^1.94.2",
    "@testing-library/jest-dom": "^5.16.5",
    "@types/node": "^20.10.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "jsdom": "^25.0.1",
    "solid-floating-ui": "^0.3.1",
    "solid-js": "^1.9.3",
    "solid-testing-library": "^0.5.0",
    "somoto": "^0.0.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "unocss": "^0.65.1",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.3.0",
    "vite-plugin-solid": "^2.11.8",
    "vitest": "^0.32.2"
  }
}
